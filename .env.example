# Required — Claude API key for the agent brain and translation
ANTHROPIC_API_KEY=your_anthropic_key_here

# Required — NewsAPI for recent news searches (free tier at newsapi.org)
NEWSAPI_KEY=your_newsapi_key_here

# Required — Google Maps for satellite imagery (free tier at console.cloud.google.com)
GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Optional — only if using Groq instead of Claude
# GROQ_API_KEY=your_groq_key_here
